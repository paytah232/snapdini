# Snapdini env — copy to `.env` in the same folder as your compose file and fill in.
# docker compose auto-loads ./.env for ${VAR} interpolation. `.env` is gitignored; this
# example is committed. Minimum to start: BASE_URL + POSTGRES_PASSWORD.

# ── Image / runtime (docker-compose.yml runs the published images) ──
# IMAGE_PREFIX=ghcr.io/paytah232/snapdini               # registry/namespace; change to use your own
# IMAGE_TAG=latest                                       # pin a release, e.g. 1.0.0 (recommended in prod)
# HTTP_PORT=8080                                         # host port nginx publishes (put TLS/proxy in front)

# ── Core ──
# BASE_URL is REQUIRED in production. It's the public URL used for QR codes, email/verify
# links, Stripe redirects + webhook, and OG tags. In prod the app refuses to trust the
# request Host header for these (anti host-header-poisoning), so if BASE_URL is unset it
# logs a security warning and falls back to the host. Set it to YOUR public https URL.
# Local default below matches docker-compose.yml's HTTP_PORT (8080).
BASE_URL=http://localhost:8080

# ── Database ──
# Password for the bundled Postgres (the compose file wires this into DATABASE_URL for you).
# Change it before any real deployment.
POSTGRES_PASSWORD=change-me-to-a-strong-password
# DATABASE_URL=                                         # override only if using an external Postgres

# RETENTION_DAYS=7
# VIDEO_MAX_SECONDS=60                                   # global video length when billing is OFF
# MAX_FILE_SIZE_MB=64                                    # per-photo upload cap (an 8K still at max quality)
# MAX_VIDEO_SIZE_MB=8192                                 # per-video upload cap (8192 = plan for 90s 8K)
# IMAGE_CONCURRENCY=                                     # parallel image-processing jobs (default = vCPU-1)
# IMAGE_QUALITY=100                                      # stored-photo JPEG quality 1–100 (default 100 = max).
#   100 = full quality, 4:4:4 (largest files). Drop to ~95/90/85 for much smaller files: <90 also
#   switches to 4:2:0 + mozjpeg for bigger savings. Full resolution is always kept (never downscaled).
#   NB: a reverse proxy in front (nginx/Traefik) must also allow large bodies — see app/nginx/default.conf
#   (client_max_body_size + proxy_request_buffering off + long proxy timeouts).

# ── Media storage (ZFS pool) ──
# UPLOADS_HOST=/bigdata/snapdini/dev                     # host dir for photos/videos (default set in compose)

# ── Email (pick ONE; Mailgun preferred when set) ──
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=Snapdini <noreply@yourdomain.com>
# MAILGUN_API_KEY=
# MAILGUN_DOMAIN=mg.yourdomain.com
# MAILGUN_BASE=https://api.mailgun.net                  # EU: https://api.eu.mailgun.net
# SUPPORT_EMAIL=support@yourdomain.com                  # contact-form recipient (unset = contact form stores only)

# ── Site admin (both unset = no admin account; no shipped default credential) ──
# ADMIN_EMAIL=you@yourdomain.com
# ADMIN_PASSWORD=change-me-strong        # only used to create the admin the first time

# ── Google sign-in (optional; both unset = Google button hidden) ──
# Create credentials at https://console.cloud.google.com/apis/credentials :
#   1) Create OAuth client ID → type "Web application".
#   2) Authorised redirect URI = <BASE_URL>/api/auth/google/callback
#      (e.g. https://yourdomain.com/api/auth/google/callback — must match BASE_URL exactly).
#   3) Copy the Client ID + Client secret here. (CSRF 'state' is handled automatically.)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# ── Billing (Stripe) — set these to switch billing ON. Leave blank = self-host/free, no Pro UI. ──
# 1) Stripe Dashboard → Developers → API keys (TEST mode) → copy "Secret key":
STRIPE_SECRET_KEY=
# 2) Stripe Dashboard → Developers → Webhooks → Add endpoint:
#       URL    = <your BASE_URL>/api/billing/webhook
#       Events = checkout.session.completed
#    Then reveal the endpoint's "Signing secret" (whsec_...) and paste it here:
STRIPE_WEBHOOK_SECRET=
BILLING_CURRENCY=usd                                    # ISO currency for prices (e.g. usd, aud, eur, gbp)
