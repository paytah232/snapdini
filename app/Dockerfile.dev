FROM node:22-alpine

# python3/make/g++ for native deps; fontconfig + DejaVu so sharp can rasterise text
# (make-og.mjs); ffmpeg for the slideshow export.
RUN apk add --no-cache python3 make g++ fontconfig ttf-dejavu ffmpeg

WORKDIR /app

COPY package*.json ./
RUN npm install && npm cache clean --force

# src/ is bind-mounted at runtime — not copied here
ENV NODE_ENV=development \
    PORT=3000 \
    DATA_DIR=/data

EXPOSE 3000

CMD ["npm", "start"]
